{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/march-madness",
      "destination": "/bracket",
      "permanent": true
    },
    {
      "source": "/rankings",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/mlb-daily-analysis",
      "destination": "/mlb",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
