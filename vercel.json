{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "ignoreCommand": "node -e \"const m=process.env.VERCEL_GIT_COMMIT_MESSAGE||'';const b=process.env.VERCEL_GIT_COMMIT_REF||'';const skip=b&&b!=='main'&&/^(test|chore|ci|docs):/i.test(m);process.exit(skip?0:1)\"",
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Surrogate-Control", "value": "no-store" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "joeknowsball.com"
        }
      ],
      "destination": "https://www.joeknowsball.com/:path*",
      "permanent": true
    },
    {
      "source": "/rankings",
      "destination": "/ncaa",
      "permanent": true
    },
    {
      "source": "/schedule",
      "destination": "/ncaa/schedule",
      "permanent": true
    },
    {
      "source": "/schedule/:gameId",
      "destination": "/ncaa/schedule/:gameId",
      "permanent": true
    },
    {
      "source": "/matchup",
      "destination": "/ncaa/matchup",
      "permanent": true
    },
    {
      "source": "/matchup/:matchupId",
      "destination": "/ncaa/matchup/:matchupId",
      "permanent": true
    },
    {
      "source": "/betting-edge",
      "destination": "/ncaa/betting-edge",
      "permanent": true
    },
    {
      "source": "/bracket",
      "destination": "/ncaa/bracket",
      "permanent": true
    },
    {
      "source": "/march-madness",
      "destination": "/ncaa/bracket",
      "permanent": true
    },
    {
      "source": "/mlb-daily-analysis",
      "destination": "/mlb",
      "permanent": true
    },
    {
      "source": "/rbc-heritage-2026-picks",
      "destination": "/pga/rbc-heritage-2026-picks",
      "permanent": true
    },
    {
      "source": "/wells-fargo-championship-2026-picks",
      "destination": "/pga/wells-fargo-championship-2026-picks",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
