{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "joeknowsball.com"
        }
      ],
      "destination": "https://www.joeknowsball.com/:path*",
      "permanent": true
    },
    {
      "source": "/rankings",
      "destination": "/ncaa",
      "permanent": true
    },
    {
      "source": "/schedule",
      "destination": "/ncaa/schedule",
      "permanent": true
    },
    {
      "source": "/schedule/:gameId",
      "destination": "/ncaa/schedule/:gameId",
      "permanent": true
    },
    {
      "source": "/matchup",
      "destination": "/ncaa/matchup",
      "permanent": true
    },
    {
      "source": "/matchup/:matchupId",
      "destination": "/ncaa/matchup/:matchupId",
      "permanent": true
    },
    {
      "source": "/betting-edge",
      "destination": "/ncaa/betting-edge",
      "permanent": true
    },
    {
      "source": "/bracket",
      "destination": "/ncaa/bracket",
      "permanent": true
    },
    {
      "source": "/march-madness",
      "destination": "/ncaa/bracket",
      "permanent": true
    },
    {
      "source": "/mlb-daily-analysis",
      "destination": "/mlb",
      "permanent": true
    },
    {
      "source": "/pga",
      "destination": "/pga/rbc-heritage-2026-picks",
      "permanent": true
    },
    {
      "source": "/pga/rbc-heritage-2026-picks/model",
      "destination": "/pga/model",
      "permanent": true
    },
    {
      "source": "/pga/rbc-heritage-2026-picks/model/table",
      "destination": "/pga/model/table",
      "permanent": true
    },
    {
      "source": "/rbc-heritage-2026-picks",
      "destination": "/pga/rbc-heritage-2026-picks",
      "permanent": true
    },
    {
      "source": "/wells-fargo-championship-2026-picks",
      "destination": "/pga/wells-fargo-championship-2026-picks",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
